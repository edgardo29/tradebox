# Copy this file to .env and replace YOUR_POSTGRES_PASSWORD with the local
# password for the tradebox_user PostgreSQL role.
DATABASE_URL=postgresql+psycopg://tradebox_user:YOUR_POSTGRES_PASSWORD@localhost:5432/tradebox_db_dev

# Cloudflare R2 storage.
# Keep the bucket private. Public bucket URLs are not required for local development.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tradebox-dev-market-data
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Databento market data.
DATABENTO_API_KEY=

# Market-data pipeline defaults.
# Default mode is safe: it reuses the existing local SPY sample metadata and does not call Databento.
MARKET_DATA_MODE=existing_sample
MARKET_DATA_SYMBOL=SPY
MARKET_DATA_VENDOR=databento
MARKET_DATA_DATASET=EQUS.MINI
MARKET_DATA_SOURCE_SCHEMA=ohlcv-1m
MARKET_DATA_TIMEFRAME=1m
MARKET_DATA_START=2024-01-02T14:30:00Z
MARKET_DATA_END=2024-01-02T14:31:00Z
MARKET_DATA_LIMIT=1
ALLOW_LIVE_DATABENTO_REQUEST=false
